# DeepResearch 环境配置
# 将此文件复制为 .env 并填写你的真实配置值
# 运行：cp .env.example .env

# =============================================================================
# TORCH/NCCL 配置（用于多 GPU 环境）
# =============================================================================
TORCHDYNAMO_VERBOSE=1
TORCHDYNAMO_DISABLE=1
NCCL_IB_TC=16
NCCL_IB_SL=5
NCCL_IB_GID_INDEX=3
NCCL_SOCKET_IFNAME=eth
NCCL_DEBUG=INFO
NCCL_IB_HCA=mlx5
NCCL_IB_TIMEOUT=22
NCCL_IB_QPS_PER_CONNECTION=8
NCCL_MIN_NCHANNELS=4
NCCL_NET_PLUGIN=none
GLOO_SOCKET_IFNAME=eth0

# =============================================================================
# DeepResearch 配置
# =============================================================================
QWEN_DOC_PARSER_USE_IDP=false
QWEN_IDP_ENABLE_CSI=false
NLP_WEB_SEARCH_ONLY_CACHE=false
NLP_WEB_SEARCH_ENABLE_READPAGE=false
NLP_WEB_SEARCH_ENABLE_SFILTER=false
QWEN_SEARCH_ENABLE_CSI=false
SPECIAL_CODE_MODE=false
PYTHONDONTWRITEBYTECODE=1

# =============================================================================
# 模型与推理超参数
# =============================================================================
MODEL_PATH=/your/model/path
DATASET=your_dataset_name
OUTPUT_PATH=/your/output/path
ROLLOUT_COUNT=3
TEMPERATURE=0.85
PRESENCE_PENALTY=1.1
MAX_WORKERS=30

# =============================================================================
# API Key 与外部服务
# =============================================================================

# Serper API：用于网页搜索与 Google Scholar
# 从这里获取你的 Key：https://serper.dev/
SERPER_KEY_ID=your_key

# Jina API：用于网页内容读取
# 从这里获取你的 Key：https://jina.ai/
JINA_API_KEYS=your_key

# 摘要模型 API（兼容 OpenAI 接口）：用于页面摘要
# 从这里获取你的 Key：https://platform.openai.com/
API_KEY=your_key
API_BASE=your_api_base
SUMMARY_MODEL_NAME=your_summary_model_name

# Dashscope API：用于文件解析（PDF、Office 等）
# 从这里获取你的 Key：https://dashscope.aliyun.com/
# 支持：qwen-omni-turbo, qwen-plus-latest
DASHSCOPE_API_KEY=your_key
DASHSCOPE_API_BASE=your_api_base
VIDEO_MODEL_NAME=your_video_model_name
VIDEO_ANALYSIS_MODEL_NAME=your_analysis_model_name

# =============================================================================
# Python 代码执行沙盒
# =============================================================================

# SandboxFusion：用于 Python 解释器的 endpoints
# 示例："http://22.16.67.220:8080,http://22.16.78.153:8080,http://22.17.10.216:8080"
# 参考：https://github.com/bytedance/SandboxFusion
SANDBOX_FUSION_ENDPOINT=your_sandbox_endpoint
TORCH_COMPILE_CACHE_DIR=./cache

# =============================================================================
# IDP 服务（高级文件解析 - 可选）
# =============================================================================

# IDP 服务：用于增强文件解析能力
# 将 USE_IDP=True 并提供凭据，可获得更强的解析效果
# 文档：https://help.aliyun.com/zh/document-mind/developer-reference/use-idp-llm-to-complete-document-summary
USE_IDP=False
IDP_KEY_ID=your_idp_key_id
IDP_KEY_SECRET=your_idp_key_secret

# =============================================================================
# 多 Worker 配置（可选）
# =============================================================================

# 通常由分布式训练框架设置
# WORLD_SIZE=1
# RANK=0
